.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
}

.tabbar {
  display: flex;
  align-items: flex-end;
  padding: 12rpx 10rpx calc(14rpx + constant(safe-area-inset-bottom));
  padding: 12rpx 10rpx calc(14rpx + env(safe-area-inset-bottom));
  background: #f3f5f6;
  border-top: 1rpx solid rgba(16, 60, 66, 0.08);
  box-shadow: 0 -8rpx 24rpx rgba(10, 26, 34, 0.06);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-item.center {
  transform: translateY(-22rpx);
}

.tab-icon {
  width: 38rpx;
  height: 38rpx;
}

.tab-text {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.1;
  white-space: nowrap;
  color: #6f8086;
}

.tab-item.active .tab-text {
  color: #14b8a6;
}

.center-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #12bb63;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 28rpx rgba(18, 187, 99, 0.34);
}

.plus {
  color: #ffffff;
  font-size: 60rpx;
  line-height: 1;
  margin-top: -8rpx;
}
